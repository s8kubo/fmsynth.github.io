<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FM Synth</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      max-width: 760px;
      margin: 0 auto;
      padding: 32px 20px;
      font-family: system-ui, sans-serif;
      background: #f4f4f1;
      color: #191919;
    }

    h1 {
      margin-bottom: 8px;
      font-size: 2rem;
    }

    .description {
      margin-top: 0;
      color: #666;
    }

    .panel {
      margin-top: 24px;
      padding: 24px;
      background: white;
      border: 1px solid #ccc;
      border-radius: 16px;
    }

    .control {
      display: grid;
      grid-template-columns: 180px 1fr 80px;
      gap: 12px;
      align-items: center;
      margin: 18px 0;
    }

    input[type="range"] {
      width: 100%;
    }

    select,
    button {
      padding: 10px;
      font: inherit;
    }

    button {
      width: 100%;
      margin-top: 16px;
      cursor: pointer;
    }

    canvas {
      display: block;
      width: 100%;
      height: 180px;
      margin-top: 24px;
      background: #111;
      border-radius: 8px;
    }

    @media (max-width: 600px) {
      .control {
        grid-template-columns: 1fr;
        gap: 6px;
      }
    }
  </style>
</head>

<body>
  <h1>FM Synthesizer</h1>
  <p class="description">
    2つの波を使って周波数変調を行います。
  </p>

  <section class="panel">
    <h2>Carrier</h2>

    <div class="control">
      <label for="carrierFrequency">周波数</label>
      <input
        id="carrierFrequency"
        type="range"
        min="40"
        max="1200"
        value="220"
        step="1"
      />
      <output id="carrierFrequencyValue">220 Hz</output>
    </div>

    <div class="control">
      <label for="carrierType">波形</label>
      <select id="carrierType">
        <option value="sine">Sine</option>
        <option value="triangle">Triangle</option>
        <option value="square">Square</option>
        <option value="sawtooth">Sawtooth</option>
      </select>
    </div>

    <h2>Modulator</h2>

    <div class="control">
      <label for="modFrequency">周波数</label>
      <input
        id="modFrequency"
        type="range"
        min="0.1"
        max="2000"
        value="110"
        step="0.1"
      />
      <output id="modFrequencyValue">110 Hz</output>
    </div>

    <div class="control">
      <label for="modType">波形</label>
      <select id="modType">
        <option value="sine">Sine</option>
        <option value="triangle">Triangle</option>
        <option value="square">Square</option>
        <option value="sawtooth">Sawtooth</option>
      </select>
    </div>

    <div class="control">
      <label for="modDepth">変調の深さ</label>
      <input
        id="modDepth"
        type="range"
        min="0"
        max="2000"
        value="220"
        step="1"
      />
      <output id="modDepthValue">220 Hz</output>
    </div>

    <div class="control">
      <label for="volume">音量</label>
      <input
        id="volume"
        type="range"
        min="0"
        max="0.3"
        value="0.1"
        step="0.001"
      />
      <output id="volumeValue">0.100</output>
    </div>

    <button id="toggleButton">再生</button>

    <canvas id="scope" width="720" height="180"></canvas>
  </section>

  <script>
    const carrierFrequencyInput =
      document.querySelector("#carrierFrequency");

    const carrierFrequencyValue =
      document.querySelector("#carrierFrequencyValue");

    const carrierTypeSelect =
      document.querySelector("#carrierType");

    const modFrequencyInput =
      document.querySelector("#modFrequency");

    const modFrequencyValue =
      document.querySelector("#modFrequencyValue");

    const modTypeSelect =
      document.querySelector("#modType");

    const modDepthInput =
      document.querySelector("#modDepth");

    const modDepthValue =
      document.querySelector("#modDepthValue");

    const volumeInput =
      document.querySelector("#volume");

    const volumeValue =
      document.querySelector("#volumeValue");

    const toggleButton =
      document.querySelector("#toggleButton");

    const canvas =
      document.querySelector("#scope");

    const canvasContext =
      canvas.getContext("2d");

    let audioContext = null;
    let carrier = null;
    let modulator = null;
    let modulationGain = null;
    let masterGain = null;
    let analyser = null;
    let animationFrameId = null;
    let isPlaying = false;

    function updateLabels() {
      carrierFrequencyValue.textContent =
        `${carrierFrequencyInput.value} Hz`;

      modFrequencyValue.textContent =
        `${Number(modFrequencyInput.value).toFixed(1)} Hz`;

      modDepthValue.textContent =
        `${modDepthInput.value} Hz`;

      volumeValue.textContent =
        Number(volumeInput.value).toFixed(3);
    }

    function smoothSet(audioParam, value) {
      if (!audioContext) return;

      const now = audioContext.currentTime;

      audioParam.cancelScheduledValues(now);
      audioParam.setTargetAtTime(value, now, 0.015);
    }

    function startSynth() {
      audioContext = new AudioContext();

      carrier = audioContext.createOscillator();
      modulator = audioContext.createOscillator();

      modulationGain = audioContext.createGain();
      masterGain = audioContext.createGain();
      analyser = audioContext.createAnalyser();

      carrier.type = carrierTypeSelect.value;
      modulator.type = modTypeSelect.value;

      carrier.frequency.value =
        Number(carrierFrequencyInput.value);

      modulator.frequency.value =
        Number(modFrequencyInput.value);

      modulationGain.gain.value =
        Number(modDepthInput.value);

      masterGain.gain.value =
        Number(volumeInput.value);

      analyser.fftSize = 2048;

      // モジュレーターの振幅を変調の深さとして調整
      modulator.connect(modulationGain);

      // キャリアの周波数をモジュレーターで揺らす
      modulationGain.connect(carrier.frequency);

      // キャリアを出力へ
      carrier.connect(masterGain);
      masterGain.connect(analyser);
      analyser.connect(audioContext.destination);

      carrier.start();
      modulator.start();

      drawWaveform();

      isPlaying = true;
      toggleButton.textContent = "停止";
    }

    function stopSynth() {
      if (!audioContext) return;

      carrier.stop();
      modulator.stop();

      cancelAnimationFrame(animationFrameId);

      audioContext.close();

      audioContext = null;
      carrier = null;
      modulator = null;
      modulationGain = null;
      masterGain = null;
      analyser = null;

      isPlaying = false;
      toggleButton.textContent = "再生";

      canvasContext.clearRect(
        0,
        0,
        canvas.width,
        canvas.height
      );
    }

    function drawWaveform() {
      if (!analyser) return;

      const data =
        new Uint8Array(analyser.fftSize);

      analyser.getByteTimeDomainData(data);

      canvasContext.clearRect(
        0,
        0,
        canvas.width,
        canvas.height
      );

      canvasContext.fillStyle = "#111";
      canvasContext.fillRect(
        0,
        0,
        canvas.width,
        canvas.height
      );

      canvasContext.strokeStyle = "#eee";
      canvasContext.lineWidth = 2;
      canvasContext.beginPath();

      const sliceWidth =
        canvas.width / data.length;

      let x = 0;

      for (let i = 0; i < data.length; i++) {
        const normalized =
          data[i] / 128;

        const y =
          normalized * canvas.height / 2;

        if (i === 0) {
          canvasContext.moveTo(x, y);
        } else {
          canvasContext.lineTo(x, y);
        }

        x += sliceWidth;
      }

      canvasContext.stroke();

      animationFrameId =
        requestAnimationFrame(drawWaveform);
    }

    toggleButton.addEventListener("click", () => {
      if (isPlaying) {
        stopSynth();
      } else {
        startSynth();
      }
    });

    carrierFrequencyInput.addEventListener("input", () => {
      updateLabels();

      if (carrier) {
        smoothSet(
          carrier.frequency,
          Number(carrierFrequencyInput.value)
        );
      }
    });

    modFrequencyInput.addEventListener("input", () => {
      updateLabels();

      if (modulator) {
        smoothSet(
          modulator.frequency,
          Number(modFrequencyInput.value)
        );
      }
    });

    modDepthInput.addEventListener("input", () => {
      updateLabels();

      if (modulationGain) {
        smoothSet(
          modulationGain.gain,
          Number(modDepthInput.value)
        );
      }
    });

    volumeInput.addEventListener("input", () => {
      updateLabels();

      if (masterGain) {
        smoothSet(
          masterGain.gain,
          Number(volumeInput.value)
        );
      }
    });

    carrierTypeSelect.addEventListener("change", () => {
      if (carrier) {
        carrier.type = carrierTypeSelect.value;
      }
    });

    modTypeSelect.addEventListener("change", () => {
      if (modulator) {
        modulator.type = modTypeSelect.value;
      }
    });

    updateLabels();
  </script>
</body>
</html>
